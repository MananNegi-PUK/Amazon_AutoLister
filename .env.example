# ==============================================================================
# Amazon Auto Lister - Environment Configuration Template
# Copy this file to '.env' and modify the values for your hosting environment.
# ==============================================================================

# Backend API Configuration
# Use local sqlite for easy testing, or postgresql for live production.
# Examples:
# SQLite: sqlite:///./data/amazon_autolister.db
# PostgreSQL: postgresql://postgres:postgres@localhost:5432/autolister
DATABASE_URL=sqlite:///./data/amazon_autolister.db

# Storage Directory for uploaded files (absolute path or relative to backend root)
UPLOAD_DIR=./data/uploads

# Redis cache and background queue connection string (optional)
# Example: redis://localhost:6379/0
REDIS_URL=

# AI & OpenAI API Configuration
# Required for embedding-based matching memory and AI suggestions
OPENAI_API_KEY=your_openai_api_key_here

# Frontend Configuration
# URL of the running backend API service
NEXT_PUBLIC_API_URL=http://localhost:8000
